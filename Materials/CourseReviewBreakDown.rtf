\f1 \
\'95 Three-tier guard chain:\
\pard\pardeftab720\li560\partightenfactor0
\cf8 \'95 Authentication \'97 no session \'e8\'96\'94? 
\f0\b \cf9 401 Unauthorized
\f1\b0 \cf8 \
\'95 Input validation \'97 Zod schema enforces integer rating 1\'965 \'e8\'96\'94? 
\f0\b \cf9 400 Bad Request
\f1\b0 \cf8 \
\'95 Domain authorisation \'97 user not enrolled \'e8\'96\'94? 
\f0\b \cf9 403 Forbidden
\f1\b0 \cf8 \
\pard\pardeftab720\li400\partightenfactor0
\cf8 \'95 On success calls 
\f3 upsertCourseRating
\f1  and returns 
\f3 \{success: true\}
\f1 \
